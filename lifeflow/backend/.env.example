# ======================================
# LifeFlow Backend - Environment Variables
# ======================================

# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lifeflow_db
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_SSL=false

# JWT Authentication
JWT_SECRET=lifeflow_super_secret_jwt_key_2026
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=lifeflow_refresh_secret_2026
JWT_REFRESH_EXPIRES_IN=30d

# OpenAI API (for AI insights & suggestions)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4-turbo-preview

# Redis (for caching & real-time)
REDIS_URL=redis://localhost:6379

# Email Notifications
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/calendar/google/callback

# Outlook Calendar
OUTLOOK_CLIENT_ID=your_outlook_client_id
OUTLOOK_CLIENT_SECRET=your_outlook_client_secret

# App Settings
DEFAULT_TIMEZONE=Africa/Cairo
DEFAULT_LANGUAGE=ar
MAX_REQUESTS_PER_MINUTE=100

# Encryption
ENCRYPTION_KEY=lifeflow_encryption_key_32chars!!
