# LifeFlow Backend — Environment Configuration
# Copy this file to .env and fill in your values

# ─── Server ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── Database ──────────────────────────────────────────────────────────────
# Set USE_SQLITE=true for local development without PostgreSQL
USE_SQLITE=false
DB_NAME=lifeflow_prod
DB_USER=lifeflow
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432

# ─── Auth (JWT) ────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_a_64_char_hex_string_here
JWT_REFRESH_SECRET=generate_another_64_char_hex_string_here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d

# ─── Redis ─────────────────────────────────────────────────────────────────
# Leave empty to use in-memory cache (development)
REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://:password@redis:6379 (with auth)

# ─── Stripe ────────────────────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create products in Stripe dashboard and add price IDs here
STRIPE_PRICE_MONTHLY=price_test_monthly_id
STRIPE_PRICE_YEARLY=price_test_yearly_id

# ─── Firebase (Push Notifications) ────────────────────────────────────────
# Get from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ─── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://lifeflow.app,https://www.lifeflow.app
FRONTEND_URL=https://lifeflow.app

# ─── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
# LOG_LEVEL=debug (for development)

# ─── Centralized AI Layer (Gemini + Groq) ────────────────────────────────────
# Both are optional; the provider selector will pick the fastest available one.
# Get Gemini key: https://aistudio.google.com/app/apikey
# Get Groq key:   https://console.groq.com/keys
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here
