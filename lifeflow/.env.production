# LifeFlow Production Environment Variables
# ==========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── App ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
CLIENT_URL=https://your-domain.com
DEFAULT_TIMEZONE=Africa/Cairo

# ── Database (PostgreSQL) ─────────────────────────────────────────────────
USE_SQLITE=false
DB_HOST=postgres
DB_PORT=5432
DB_NAME=lifeflow_db
DB_USER=lifeflow
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_SSL=false

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_256_BITS
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Stripe ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# ── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1
NEXT_PUBLIC_SOCKET_URL=https://your-domain.com

# ── Email (Optional for notifications) ────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG....
EMAIL_FROM=noreply@lifeflow.app

# ── Firebase (Mobile push notifications) ──────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@your-project.iam.gserviceaccount.com
